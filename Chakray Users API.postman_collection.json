    {
      "name": "Crear Usuario",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"name\": \"Arturo Chavez\",\r\n  \"email\": \"arturo@email.com\",\r\n  \"phone\": \"5551234567\",\r\n  \"taxId\": \"AARR990101XXX\",\r\n  \"password\": \"mypassword123\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users"
          ]
        },
        "description": "Crea un nuevo usuario en el sistema.\n\nLa contraseña se cifra utilizando AES256 antes de almacenarse.\n\nEl campo created_at se genera automáticamente utilizando la zona horaria de Madagascar."
      },
      "response": []
